# ── OpenRouter（模型网关，仅服务端读取）──
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# ── Supabase ──
# URL 与 anon key 为公开配置，可暴露给客户端（受 RLS 保护）。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service role key 绕过 RLS，仅限服务端、仅限离线/管理任务使用。
# Batch A 的请求路径（/api/forge、/api/sessions/:id）不使用 service role：
# 它们以「anon key + 用户 Auth cookie」身份读写，依赖 RLS 做用户隔离。
# 此处保留占位，便于后续迁移/后台任务接入；绝不可在客户端暴露。
SUPABASE_SERVICE_ROLE_KEY=

# ── 可选观测（I-14，全部可选；不填则观测 scaffold 为 no-op，应用照常运行）──
# 服务端错误上报（非公开，仅服务端读取）：
SENTRY_DSN=
# 前端事件（公开配置，构建期注入客户端）：
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
